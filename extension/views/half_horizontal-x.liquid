{% comment %}
  HA Weather — HALF_HORIZONTAL layout for the TRMNL X (1872x702, 4-bit greyscale).
  Current conditions on the left, today's + tomorrow's forecast, then AQI.
  Grayscale-aware variant of half_horizontal.liquid; data exposed as `source_1`.
  Keep the icon STYLE + CAPTURE block at the top.
{% endcomment %}
<div class="screen">
  <div class="view view--half_horizontal">
    <div class="layout layout--col">
      <!-- BEGIN extension content -->

      {% comment %} ===== weather icon definitions (paste once, keep at top) ===== {% endcomment %}
      <style>
        .wx-icon { display: block; width: 130px; height: 130px; margin: 0 auto; overflow: visible; }
        .wx-lg .wx-icon { width: 210px; height: 210px; }
        .aqi-face { display: block; width: 156px; height: 156px; margin: 8px auto; }
        .xmute { color: #5a5a5a; }
      </style>
      {% capture svg_open %}<svg class="wx-icon" viewBox="0 0 24 24" width="40" height="40" fill="black">{% endcapture %}
      {% capture svg_sunny %}{{ svg_open }}<path d="M7.6 12a4.4 4.4 0 1 0 8.8 0a4.4 4.4 0 1 0 -8.8 0Z"/><path d="M12.0 1.2L13.35 5.8L10.65 5.8Z"/><path d="M19.64 4.36L17.34 8.57L15.43 6.66Z"/><path d="M22.8 12.0L18.2 13.35L18.2 10.65Z"/><path d="M19.64 19.64L15.43 17.34L17.34 15.43Z"/><path d="M12.0 22.8L10.65 18.2L13.35 18.2Z"/><path d="M4.36 19.64L6.66 15.43L8.57 17.34Z"/><path d="M1.2 12.0L5.8 10.65L5.8 13.35Z"/><path d="M4.36 4.36L8.57 6.66L6.66 8.57Z"/></svg>{% endcapture %}
      {% capture svg_clear_night %}{{ svg_open }}<path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>{% endcapture %}
      {% capture svg_partlycloudy %}{{ svg_open }}<path d="M4.5 7a3 3 0 1 0 6 0a3 3 0 1 0 -6 0Z"/><path d="M7.5 0.4L8.55 2.6L6.45 2.6Z"/><path d="M2.83 2.33L5.13 3.15L3.65 4.63Z"/><path d="M0.9 7.0L3.1 5.95L3.1 8.05Z"/><path d="M2.83 11.67L3.65 9.37L5.13 10.85Z"/><path d="M9.9 13.5a3.6 3.6 0 1 0 7.2 0a3.6 3.6 0 1 0 -7.2 0Z"/><path d="M7.9 15.8a2.9 2.9 0 1 0 5.8 0a2.9 2.9 0 1 0 -5.8 0Z"/><path d="M13.6 15.8a2.9 2.9 0 1 0 5.8 0a2.9 2.9 0 1 0 -5.8 0Z"/><path d="M10.8 14.5h5.7v4.2h-5.7z"/></svg>{% endcapture %}
      {% capture svg_cloudy %}{{ svg_open }}<path d="M7.8 11.5a4.2 4.2 0 1 0 8.4 0a4.2 4.2 0 1 0 -8.4 0Z"/><path d="M4.9 14a3.3 3.3 0 1 0 6.6 0a3.3 3.3 0 1 0 -6.6 0Z"/><path d="M12.5 14a3.3 3.3 0 1 0 6.6 0a3.3 3.3 0 1 0 -6.6 0Z"/><path d="M8.2 13h7.6v4.3h-7.6z"/></svg>{% endcapture %}
      {% capture svg_fog %}{{ svg_open }}<path d="M8.5 8.5a3.5 3.5 0 1 0 7.0 0a3.5 3.5 0 1 0 -7.0 0Z"/><path d="M5.7 10a2.8 2.8 0 1 0 5.6 0a2.8 2.8 0 1 0 -5.6 0Z"/><path d="M12.2 10a2.8 2.8 0 1 0 5.6 0a2.8 2.8 0 1 0 -5.6 0Z"/><path d="M8.5 9h6.5v3.5h-6.5z"/><path d="M3.5 15.5h17v1.7h-17z"/><path d="M5.5 19h13v1.7h-13z"/></svg>{% endcapture %}
      {% capture svg_rainy %}{{ svg_open }}<path d="M7.8 11.5a4.2 4.2 0 1 0 8.4 0a4.2 4.2 0 1 0 -8.4 0Z"/><path d="M4.9 14a3.3 3.3 0 1 0 6.6 0a3.3 3.3 0 1 0 -6.6 0Z"/><path d="M12.5 14a3.3 3.3 0 1 0 6.6 0a3.3 3.3 0 1 0 -6.6 0Z"/><path d="M8.2 13h7.6v4.3h-7.6z"/><path d="M7.9 18.5h1.2v3.3h-1.2z"/><path d="M11.4 19.5h1.2v3.3h-1.2z"/><path d="M14.9 18.5h1.2v3.3h-1.2z"/></svg>{% endcapture %}
      {% capture svg_snowy %}{{ svg_open }}<path d="M7.8 11.5a4.2 4.2 0 1 0 8.4 0a4.2 4.2 0 1 0 -8.4 0Z"/><path d="M4.9 14a3.3 3.3 0 1 0 6.6 0a3.3 3.3 0 1 0 -6.6 0Z"/><path d="M12.5 14a3.3 3.3 0 1 0 6.6 0a3.3 3.3 0 1 0 -6.6 0Z"/><path d="M8.2 13h7.6v4.3h-7.6z"/><path d="M7.4 20a1.1 1.1 0 1 0 2.2 0a1.1 1.1 0 1 0 -2.2 0Z"/><path d="M10.9 21.2a1.1 1.1 0 1 0 2.2 0a1.1 1.1 0 1 0 -2.2 0Z"/><path d="M14.4 20a1.1 1.1 0 1 0 2.2 0a1.1 1.1 0 1 0 -2.2 0Z"/></svg>{% endcapture %}
      {% capture svg_lightning %}{{ svg_open }}<path d="M7.8 11.5a4.2 4.2 0 1 0 8.4 0a4.2 4.2 0 1 0 -8.4 0Z"/><path d="M4.9 14a3.3 3.3 0 1 0 6.6 0a3.3 3.3 0 1 0 -6.6 0Z"/><path d="M12.5 14a3.3 3.3 0 1 0 6.6 0a3.3 3.3 0 1 0 -6.6 0Z"/><path d="M8.2 13h7.6v4.3h-7.6z"/><path d="M12.5 13L8.5 19.5L11.2 19.5L9.8 23.5L15 16.5L12.2 16.5L14 13Z"/></svg>{% endcapture %}
      {% capture svg_windy %}{{ svg_open }}<path d="M2 7.2h13v1.8h-13z"/><path d="M2 11.1h18v1.8h-18z"/><path d="M2 15h10.5v1.8h-10.5z"/></svg>{% endcapture %}
      {% capture svg_alert %}{{ svg_open }}<path fill-rule="evenodd" d="M12 3 22.5 21.5 1.5 21.5Z M11 9.5 H13 V15 H11 Z M11 16.8 H13 V18.8 H11 Z"/></svg>{% endcapture %}
      {% comment %} ===== AQI level-of-concern faces (black fills only) ===== {% endcomment %}
      {% capture face_open %}<svg class="aqi-face" viewBox="0 0 24 24" width="54" height="54" fill="black"><path fill-rule="evenodd" d="M0.5 12A11.5 11.5 0 1 0 23.5 12A11.5 11.5 0 1 0 0.5 12ZM1.8 12A10.2 10.2 0 1 0 22.2 12A10.2 10.2 0 1 0 1.8 12Z"/>{% endcapture %}
      {% capture face_eyes %}<path d="M6.8 9a1.7 1.7 0 1 0 3.4 0a1.7 1.7 0 1 0 -3.4 0Z"/><path d="M13.8 9a1.7 1.7 0 1 0 3.4 0a1.7 1.7 0 1 0 -3.4 0Z"/>{% endcapture %}
      {% capture face_good %}{{ face_open }}{{ face_eyes }}<path d="M5.5 12.5A7 7 0 0 0 18.5 12.5Z"/></svg>{% endcapture %}
      {% capture face_moderate %}{{ face_open }}{{ face_eyes }}<path d="M7 13A5.5 5.5 0 0 0 17 13Z"/></svg>{% endcapture %}
      {% capture face_usg %}{{ face_open }}{{ face_eyes }}<path d="M8 14.6H16V16.2H8Z"/></svg>{% endcapture %}
      {% capture face_unhealthy %}{{ face_open }}{{ face_eyes }}<path d="M7 16.8A5.5 5.5 0 0 1 17 16.8Z"/></svg>{% endcapture %}
      {% capture face_veryunhealthy %}{{ face_open }}{{ face_eyes }}<path d="M5.5 17.6A7 7 0 0 1 18.5 17.6Z"/></svg>{% endcapture %}
      {% capture face_hazardous %}{{ face_open }}<path d="M6.8 9.4 10.2 8 10.2 9.6Z"/><path d="M17.2 9.4 13.8 8 13.8 9.6Z"/><path d="M9.4 16.2a2.6 2.6 0 1 0 5.2 0a2.6 2.6 0 1 0 -5.2 0Z"/></svg>{% endcapture %}
      {% comment %} ===== end icon definitions ===== {% endcomment %}

      {% assign w = source_1.weather %}
      {% assign aq = source_1.air_quality %}
      <div style="flex:1;width:100%;display:flex;align-items:center;justify-content:space-between;gap:48px">

        <!-- current conditions, anchored left -->
        <div style="display:flex;flex-direction:column;align-items:center;flex:0 0 auto;text-align:center">
          {% case w.condition %}
            {% when 'sunny' %}{% assign wx = svg_sunny %}
            {% when 'clear-night' %}{% assign wx = svg_clear_night %}
            {% when 'partlycloudy' %}{% assign wx = svg_partlycloudy %}
            {% when 'cloudy' %}{% assign wx = svg_cloudy %}
            {% when 'fog' %}{% assign wx = svg_fog %}
            {% when 'rainy', 'pouring' %}{% assign wx = svg_rainy %}
            {% when 'snowy', 'snowy-rainy', 'hail' %}{% assign wx = svg_snowy %}
            {% when 'lightning', 'lightning-rainy' %}{% assign wx = svg_lightning %}
            {% when 'windy', 'windy-variant' %}{% assign wx = svg_windy %}
            {% else %}{% assign wx = svg_alert %}
          {% endcase %}
          <div class="wx-lg">{{ wx }}</div>
          {% assign _t = w.temperature | round %}<span class="value {% if _t >= 100 or _t <= -10 %}value--mega{% else %}value--giga{% endif %} value--tnums">{{ _t }}{{ w.temperature_unit }}</span>
          <span class="label label--xxlarge">{{ w.condition_label }}</span>
        </div>

        <!-- two-day forecast + AQI, shifted to the right edge -->
        <div style="display:flex;align-items:center;gap:72px;flex:0 0 auto">
          {% for day in source_1.forecast limit:2 %}
          <div style="display:flex;flex-direction:column;align-items:center;text-align:center">
            <span class="label label--xxlarge xmute">{{ day.day }}</span>
            {% case day.condition %}
              {% when 'sunny' %}{% assign wx = svg_sunny %}
              {% when 'clear-night' %}{% assign wx = svg_clear_night %}
              {% when 'partlycloudy' %}{% assign wx = svg_partlycloudy %}
              {% when 'cloudy' %}{% assign wx = svg_cloudy %}
              {% when 'fog' %}{% assign wx = svg_fog %}
              {% when 'rainy', 'pouring' %}{% assign wx = svg_rainy %}
              {% when 'snowy', 'snowy-rainy', 'hail' %}{% assign wx = svg_snowy %}
              {% when 'lightning', 'lightning-rainy' %}{% assign wx = svg_lightning %}
              {% when 'windy', 'windy-variant' %}{% assign wx = svg_windy %}
              {% else %}{% assign wx = svg_alert %}
            {% endcase %}
            {{ wx }}
            <span class="value value--xxlarge value--tnums">{{ day.high | round }}&deg;/{{ day.low | round }}&deg;</span>
          </div>
          {% endfor %}
          {% if aq.available %}
          <div style="display:flex;flex-direction:column;align-items:center;text-align:center">
            <span class="label label--xxlarge xmute">AQI</span>
            <span class="value value--xxxlarge value--tnums">{{ aq.value }}</span>
            {% case aq.level %}
              {% when 1 %}{% assign face = face_good %}
              {% when 2 %}{% assign face = face_moderate %}
              {% when 3 %}{% assign face = face_usg %}
              {% when 4 %}{% assign face = face_unhealthy %}
              {% when 5 %}{% assign face = face_veryunhealthy %}
              {% else %}{% assign face = face_hazardous %}
            {% endcase %}
            {{ face }}
            <span class="label label--xlarge xmute">{{ aq.category_short }}</span>
          </div>
          {% endif %}
        </div>

      </div>

      <div class="title_bar" style="margin-top:auto; width:100%; position:relative">
        <svg preserveAspectRatio="none" fill="#d9d9d9" style="position:absolute;left:0;top:0;right:0;bottom:0;width:100%;height:100%;z-index:0"><path d="M0 0H4000V400H0Z"/></svg>
        <span class="title" style="position:relative;z-index:1;color:#1a1a1a">Updated {{ source_1.generated_label }}</span>
      </div>

      <!-- END extension content -->
    </div>
  </div>
</div>
